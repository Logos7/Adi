root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{bat,cmd,ps1}]
end_of_line = crlf

[*.md]
trim_trailing_whitespace = false

[*.{png,jpg,jpeg,gif,ico,zip,vsix,fs,bit,bin,exe,dll,pdf}]
insert_final_newline = false
trim_trailing_whitespace = false
