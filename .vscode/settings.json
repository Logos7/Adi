{
  "files.associations": {
    "*.sutra": "sutra",
    "*.cst": "tcl"
  },
  "python.analysis.extraPaths": [
    "./tools",
    "./sutra",
    "./cores/bija"
  ],
  "files.exclude": {
    "**/__pycache__": true
  },
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": "entity.name.label.definition.sutra",
        "settings": {
          "fontStyle": "bold",
          "foreground": "#FFD166"
        }
      },
      {
        "scope": "variable.other.label.reference.sutra",
        "settings": {
          "fontStyle": "bold",
          "foreground": "#E6C15C"
        }
      },
      {
        "scope": "comment.line.semicolon.sutra",
        "settings": {
          "fontStyle": "italic",
          "foreground": "#6A9955"
        }
      },
      {
        "scope": "keyword.control.flow.sutra",
        "settings": {
          "fontStyle": "bold",
          "foreground": "#C586C0"
        }
      },
      {
        "scope": "support.function.framebuffer.sutra",
        "settings": {
          "fontStyle": "bold",
          "foreground": "#4FC1FF"
        }
      },
      {
        "scope": "support.function.macro.uart.sutra",
        "settings": {
          "foreground": "#DCDCAA"
        }
      },
      {
        "scope": "keyword.operator.integer.sutra",
        "settings": {
          "foreground": "#569CD6"
        }
      },
      {
        "scope": "keyword.operator.fixed.sutra",
        "settings": {
          "foreground": "#B5CEA8"
        }
      },
      {
        "scope": "keyword.operator.comparison.sutra",
        "settings": {
          "foreground": "#D7BA7D"
        }
      },
      {
        "scope": "keyword.operator.bool.sutra",
        "settings": {
          "foreground": "#9CDCFE"
        }
      },
      {
        "scope": "support.function.macro.complex.sutra",
        "settings": {
          "foreground": "#C586C0"
        }
      },
      {
        "scope": "variable.other.register.gpr.sutra",
        "settings": {
          "foreground": "#9CDCFE"
        }
      },
      {
        "scope": "variable.other.register.scratch.sutra",
        "settings": {
          "foreground": "#4EC9B0"
        }
      },
      {
        "scope": "variable.other.register.bool.sutra",
        "settings": {
          "foreground": "#CE9178"
        }
      },
      {
        "scope": "variable.other.register.complex.sutra",
        "settings": {
          "foreground": "#C586C0"
        }
      },
      {
        "scope": "storage.modifier.memory.sutra",
        "settings": {
          "foreground": "#D7BA7D"
        }
      },
      {
        "scope": "constant.other.address.sutra",
        "settings": {
          "foreground": "#FFB86C"
        }
      },
      {
        "scope": "support.constant.mmio.sutra",
        "settings": {
          "foreground": "#FFB86C"
        }
      },
      {
        "scope": "support.constant.gpio.sutra",
        "settings": {
          "foreground": "#F78C6C"
        }
      }
    ]
  }
}
