module DVI_TX_Top (
  pix_clk,
  serial_clk,
  I_rst_d,
  pll_lock,
  video_de,
  video_vs,
  video_hs,
  video_r,
  O_tmds_clk_p,
  O_tmds_clk_n,
  n36_6,
  O_tmds_data_p,
  O_tmds_data_n
)
;
input pix_clk;
input serial_clk;
input I_rst_d;
input pll_lock;
input video_de;
input video_vs;
input video_hs;
input [7:7] video_r;
output O_tmds_clk_p;
output O_tmds_clk_n;
output n36_6;
output [2:0] O_tmds_data_p;
output [2:0] O_tmds_data_n;
wire VCC;
wire GND;
  \~rgb2dvi.DVI_TX_Top  rgb2dvi_inst (
    .pix_clk(pix_clk),
    .serial_clk(serial_clk),
    .I_rst_d(I_rst_d),
    .pll_lock(pll_lock),
    .video_de(video_de),
    .video_vs(video_vs),
    .video_hs(video_hs),
    .video_r(video_r[7]),
    .O_tmds_clk_p(O_tmds_clk_p),
    .O_tmds_clk_n(O_tmds_clk_n),
    .n36_6(n36_6),
    .O_tmds_data_p(O_tmds_data_p[2:0]),
    .O_tmds_data_n(O_tmds_data_n[2:0])
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* DVI_TX_Top */
module key_led_ctrl (
  pix_clk,
  key_pressed,
  n36_6,
  mode_reg,
  key_sync,
  n42_6,
  O_led_d_4_4,
  O_led_d_3_4,
  O_led_d_2_4,
  O_led_d_1_4,
  O_led_d_0_4
)
;
input pix_clk;
input key_pressed;
input n36_6;
input [0:0] mode_reg;
input [1:0] key_sync;
output n42_6;
output O_led_d_4_4;
output O_led_d_3_4;
output O_led_d_2_4;
output O_led_d_1_4;
output O_led_d_0_4;
wire n40_3;
wire n37_6;
wire n63_10;
wire n62_10;
wire n60_8;
wire dir_7;
wire n64_12;
wire dir_9;
wire dir;
wire n39_8;
wire [2:1] press_cnt;
wire [4:0] led_r;
wire VCC;
wire GND;
  LUT4 n40_s0 (
    .F(n40_3),
    .I0(mode_reg[0]),
    .I1(press_cnt[1]),
    .I2(press_cnt[2]),
    .I3(dir) 
);
defparam n40_s0.INIT=16'h78E0;
  LUT4 n37_s1 (
    .F(n37_6),
    .I0(press_cnt[2]),
    .I1(press_cnt[1]),
    .I2(mode_reg[0]),
    .I3(dir) 
);
defparam n37_s1.INIT=16'h1CC2;
  LUT2 n63_s4 (
    .F(n63_10),
    .I0(press_cnt[1]),
    .I1(press_cnt[2]) 
);
defparam n63_s4.INIT=4'hE;
  LUT3 n62_s4 (
    .F(n62_10),
    .I0(press_cnt[1]),
    .I1(mode_reg[0]),
    .I2(press_cnt[2]) 
);
defparam n62_s4.INIT=8'hF8;
  LUT3 n60_s3 (
    .F(n60_8),
    .I0(press_cnt[1]),
    .I1(mode_reg[0]),
    .I2(press_cnt[2]) 
);
defparam n60_s3.INIT=8'hE0;
  LUT3 dir_s3 (
    .F(dir_7),
    .I0(mode_reg[0]),
    .I1(press_cnt[2]),
    .I2(dir) 
);
defparam dir_s3.INIT=8'h7E;
  LUT3 n64_s5 (
    .F(n64_12),
    .I0(mode_reg[0]),
    .I1(press_cnt[1]),
    .I2(press_cnt[2]) 
);
defparam n64_s5.INIT=8'hFE;
  LUT4 dir_s4 (
    .F(dir_9),
    .I0(dir_7),
    .I1(press_cnt[1]),
    .I2(key_sync[1]),
    .I3(key_sync[0]) 
);
defparam dir_s4.INIT=16'h0100;
  LUT3 n42_s2 (
    .F(n42_6),
    .I0(key_sync[1]),
    .I1(key_sync[0]),
    .I2(mode_reg[0]) 
);
defparam n42_s2.INIT=8'hB4;
  DFFCE press_cnt_2_s0 (
    .Q(press_cnt[2]),
    .D(n40_3),
    .CLK(pix_clk),
    .CE(key_pressed),
    .CLEAR(n36_6) 
);
  DFFCE press_cnt_1_s0 (
    .Q(press_cnt[1]),
    .D(n37_6),
    .CLK(pix_clk),
    .CE(key_pressed),
    .CLEAR(n36_6) 
);
  DFFC led_r_4_s0 (
    .Q(led_r[4]),
    .D(n60_8),
    .CLK(pix_clk),
    .CLEAR(n36_6) 
);
  DFFC led_r_3_s0 (
    .Q(led_r[3]),
    .D(press_cnt[2]),
    .CLK(pix_clk),
    .CLEAR(n36_6) 
);
  DFFC led_r_2_s0 (
    .Q(led_r[2]),
    .D(n62_10),
    .CLK(pix_clk),
    .CLEAR(n36_6) 
);
  DFFC led_r_1_s0 (
    .Q(led_r[1]),
    .D(n63_10),
    .CLK(pix_clk),
    .CLEAR(n36_6) 
);
  DFFC led_r_0_s0 (
    .Q(led_r[0]),
    .D(n64_12),
    .CLK(pix_clk),
    .CLEAR(n36_6) 
);
  DFFPE dir_s0 (
    .Q(dir),
    .D(n39_8),
    .CLK(pix_clk),
    .CE(dir_9),
    .PRESET(n36_6) 
);
  INV O_led_d_4_s0 (
    .O(O_led_d_4_4),
    .I(led_r[4]) 
);
  INV O_led_d_3_s0 (
    .O(O_led_d_3_4),
    .I(led_r[3]) 
);
  INV O_led_d_2_s0 (
    .O(O_led_d_2_4),
    .I(led_r[2]) 
);
  INV O_led_d_1_s0 (
    .O(O_led_d_1_4),
    .I(led_r[1]) 
);
  INV O_led_d_0_s0 (
    .O(O_led_d_0_4),
    .I(led_r[0]) 
);
  INV n39_s3 (
    .O(n39_8),
    .I(dir) 
);
  VCC VCC_cZ (
    .V(VCC)
);
  GND GND_cZ (
    .G(GND)
);
endmodule /* key_led_ctrl */
module video_top (
  I_clk,
  I_rst,
  I_key,
  O_led,
  running,
  O_tmds_clk_p,
  O_tmds_clk_n,
  O_tmds_data_p,
  O_tmds_data_n
)
;
input I_clk;
input I_rst;
input I_key;
output [4:0] O_led;
output running;
output O_tmds_clk_p;
output O_tmds_clk_n;
output [2:0] O_tmds_data_p;
output [2:0] O_tmds_data_n;
wire I_clk_d;
wire I_rst_d;
wire I_key_d;
wire hdmi_rst_n;
wire n72_7;
wire n71_7;
wire n70_7;
wire n69_7;
wire n68_7;
wire n67_7;
wire n66_7;
wire n65_7;
wire n64_7;
wire n63_7;
