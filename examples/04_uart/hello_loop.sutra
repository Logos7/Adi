; Sutra v1.4 â€” UART hello loop
; WysyĹ‚a "ADI\n" co chwilÄ™ i mruga LED0.

start:
    move @led0, high

    move r0, 65
    write_tx r0
    move r0, 68
    write_tx r0
    move r0, 73
    write_tx r0
    move r0, 10
    write_tx r0

    wait 27000000
    move @led0, low
    wait 27000000
    jump start