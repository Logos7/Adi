; Sutra v1.3 — UART frame 64x64, pixel = x + y

start:
    move @uart_tx, 65
    move @uart_tx, 68
    move @uart_tx, 73
    move @uart_tx, 48
    move @uart_tx, 64
    move @uart_tx, 64

    move r5, 0
row_loop:
    move r4, 0
col_loop:
    iadd r0, r4, r5
    move @uart_tx, r0

    iadd r4, r4, 1
    cmp.lt b0, r4, 64
    (b0) jump col_loop

    iadd r5, r5, 1
    cmp.lt b0, r5, 64
    (b0) jump row_loop

    jump start
