; Sutra v1.4
; LED chaser.
; low = on, high = off.

start:
    move @led5, high

loop:
    move @led0, low
    move @led1, high
    move @led2, high
    move @led3, high
    move @led4, high
    wait 9000000

    move @led0, high
    move @led1, low
    wait 9000000

    move @led1, high
    move @led2, low
    wait 9000000

    move @led2, high
    move @led3, low
    wait 9000000

    move @led3, high
    move @led4, low
    wait 9000000

    move @led4, high
    jump loop
