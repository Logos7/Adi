; Sutra v1.4 â€” UART frame 64x64, pixel = y

start:
    move r0, 65
    write_tx r0
    move r0, 68
    write_tx r0
    move r0, 73
    write_tx r0
    move r0, 48
    write_tx r0
    move r0, 64
    write_tx r0
    move r0, 64
    write_tx r0

    move r5, 0
row_loop:
    move r4, 0
col_loop:
    move r0, r5
    write_tx r0

    inc r4
    blt r4, 64, col_loop

    inc r5
    blt r5, 64, row_loop

    jump start