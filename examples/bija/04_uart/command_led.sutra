; Sutra v1.4 â€” sterowanie LED0 po UART.
; '1' zapala LED0, '0' gasi LED0, inne znaki sÄ… odsyĹ‚ane echem.

loop:
    read_rx r0

    beq r0, 49, led_on
    beq r0, 48, led_off

    write_tx r0
    jump loop

led_on:
    move @led0, low
    write_tx r0
    jump loop

led_off:
    move @led0, high
    write_tx r0
    jump loop