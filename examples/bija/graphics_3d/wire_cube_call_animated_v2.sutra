; Sutra v1.4 - large animated perspective wireframe cube.
; Requires Brahma-Bija RTL and assembler with call/return support.
; ADI0 viewer protocol: every animation step sends a full 64x64 frame.
; Projection is precomputed; Sutra tests line equations while streaming pixels.
; The animation ping-pongs through eight small-angle frames to avoid a hard wrap jump.

start:
    call send_frame_0
    call send_frame_1
    call send_frame_2
    call send_frame_3
    call send_frame_4
    call send_frame_5
    call send_frame_6
    call send_frame_7
    call send_frame_6
    call send_frame_5
    call send_frame_4
    call send_frame_3
    call send_frame_2
    call send_frame_1
    jump start

send_frame_0:
    call send_header
    move r5, 0
row_loop_0:
    move r4, 0
col_loop_0:
    call cube_pixel_0
    move r0, r11
    call put_byte
    inc r4
    blt r4, 64, col_loop_0
    inc r5
    blt r5, 64, row_loop_0
    return

cube_pixel_0:
    move r11, 0
    ; edge 0: (7,44) -> (51,48)
