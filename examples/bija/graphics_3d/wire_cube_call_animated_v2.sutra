    move r10, 49
    move r12, 52
    call test_line
    ; edge 10: (30,4) -> (57,19)
    move r6, 30
    move r7, 4
    move r8, 57
    move r9, 19
    move r10, 4
    move r12, 19
    call test_line
    ; edge 11: (14,15) -> (36,23)
    move r6, 14
    move r7, 15
    move r8, 36
    move r9, 23
    move r10, 15
    move r12, 23
    call test_line
    return

send_header:
    move r0, 65
    call put_byte
    move r0, 68
    call put_byte
    move r0, 73
    call put_byte
    move r0, 48
    call put_byte
    move r0, 64
    call put_byte
    move r0, 64
    call put_byte
    return

put_byte:
    write_tx r0
    return

test_line:
    beq r11, 48, test_line_done
    blt r4, r6, test_line_done
    bgt r4, r8, test_line_done
    blt r5, r10, test_line_done
    bgt r5, r12, test_line_done

    isub r13, r8, r6
    isub r14, r9, r7
    isub r15, r4, r6
    isub r16, r5, r7
    imul r17, r14, r15
    imul r18, r13, r16
    isub r19, r17, r18
    bge r19, 0, cross_abs_done
    isub r19, 0, r19
cross_abs_done:
    move r20, r14
    bge r20, 0, dy_abs_done
    isub r20, 0, r20
dy_abs_done:
    bge r13, r20, use_dx_as_limit
    jump limit_ready
use_dx_as_limit:
    move r20, r13
limit_ready:
    shr r20, r20, 2
    ble r19, r20, test_line_set
    return
test_line_set:
    move r11, 48
test_line_done:
    return
