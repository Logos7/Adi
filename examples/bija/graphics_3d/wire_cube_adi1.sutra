 inc r23
 move @r23, 0.195090
 inc r23
 move @r23, 0.098017
 inc r23
 move @r23, 0.0
 inc r23
 move @r23, -0.098017
 inc r23
 move @r23, -0.195090
 inc r23
 move @r23, -0.290285
 inc r23
 move @r23, -0.382683
 inc r23
