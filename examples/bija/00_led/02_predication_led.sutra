; Sutra v1.4
; Predication demo.
; If r0 == 42 then LED1 turns on.

start:
    move @led0, low
    move @led1, high
    move @led5, high

loop:
    move r0, 42
    cmp.eq b0, r0, 42

    (b0) move @led1, low
    (!b0) move @led1, high

    wait 27000000

    move r0, 7
    cmp.eq b0, r0, 42

    (b0) move @led1, low
    (!b0) move @led1, high

    wait 27000000
    jump loop
