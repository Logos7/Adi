; Sutra v1.4
; Integer and fixed-point demo.
; LED1 on means integer math passed.
; LED2 on means fixed-point math passed.
; low = on, high = off.

start:
    move @led0, low
    move @led1, high
    move @led2, high
    move @led5, high

    imul r0, 6, 7
    cmp.eq b0, r0, 42
    (b0) move @led1, low
    (!b0) move @led5, low

    fmul r1, 1.5, 2.0
    cmp.feq b1, r1, 3.0, 0.0001
    (b1) move @led2, low
    (!b1) move @led5, low

loop:
    wait 27000000
    jump loop
