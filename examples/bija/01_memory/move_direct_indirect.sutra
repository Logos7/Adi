; Sutra v1.3 — pamięć direct/indirect i adresy
; value        = 123
; @7           = pamięć pod adresem 7
; @r3          = pamięć pod adresem zapisanym w r3
; &uart_tx     = adres UART_TX jako zwykła liczba

start:
    move r1, 123
    move @7, r1
    move r2, @7

    move r3, 9
    move @r3, r2
    move r4, @r3

    move r5, &uart_tx
    cmp.eq b0, r2, r4
    move @led0, b0
    halt
