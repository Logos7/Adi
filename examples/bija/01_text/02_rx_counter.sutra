; Sutra v1.4
; UART RX counter.
; Every received byte prints "RX\n".
; LED1 blinks on every received byte.
; low = on, high = off.

start:
    move @led0, low
    move @led1, high
    move @led5, high

loop:
    read_rx r0

    move @led1, low

    move r0, 82
    write_tx r0
    move r0, 88
    write_tx r0
    move r0, 10
    write_tx r0

    wait 3000000
    move @led1, high

    jump loop
