{
  "name": "sutra",
  "displayName": "Sutra Assembler",
  "description": "Syntax highlighting for Sutra v1.6 (Brahma-Bija assembler)",
  "version": "1.6.0",
  "publisher": "adi-project",
  "engines": {
    "vscode": "^1.50.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "sutra",
        "aliases": [
          "Sutra",
          "sutra"
        ],
        "extensions": [
          ".sutra"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sutra",
        "scopeName": "source.sutra",
        "path": "./syntaxes/sutra.tmLanguage.json"
      }
    ]
  }
}
